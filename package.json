{
  "name": "@verils/agentbaton",
  "version": "0.1.0",
  "description": "一个基于 CLI 的编程智能体配置管理器",
  "type": "module",
  "bin": {
    "agentbaton": "dist/cli.js"
  },
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf dist",
    "dev": "vite build --watch",
    "lint": "eslint src --ext .ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "agent",
    "ai",
    "config",
    "manager"
  ],
  "author": "verils@qq.com",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "commander": "^15.0.0",
    "smol-toml": "^1.6.1"
  }
}
